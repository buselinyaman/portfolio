<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="admin-wrapper">
            <aside class="admin-sidebar">
                <div class="sidebar-brand">
                    <span class="brand-dot"></span>
                    <span>Admin Panel</span>
                </div>
                <nav class="sidebar-nav">
                    <a href="/Admin/Dashboard" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                        Dashboard
                    </a>
                    <a href="/Admin/Projects" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Project") == true ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                        Projeler
                    </a>
                    <a href="/Admin/Events" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Event") == true ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Etkinlikler
                    </a>
                    <a href="/Admin/Skills" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Skill") == true ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        Yetenekler
                    </a>
                    <a href="/Admin/About" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Hakkımda
                    </a>
                </nav>
                <div class="sidebar-footer">
                    <a href="/" target="_blank" class="preview-link">Siteyi Görüntüle ↗</a>
                    <a href="/Admin/Logout" class="logout-btn">Çıkış Yap</a>
                </div>
            </aside>
            <main class="admin-main">
                @if (TempData["Success"] != null)
                {
                    <div class="alert-success">@TempData["Success"]</div>
                }
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }
    <script src="~/js/admin.js" asp-append-version="true"></script>
</body>
</html>
