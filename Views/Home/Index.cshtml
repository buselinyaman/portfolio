@{
    ViewData["Title"] = "Portfolio";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var about = ViewBag.About as PortfolioSite.Models.AboutInfo;
    var projects = ViewBag.Projects as List<PortfolioSite.Models.Project>;
    var events = ViewBag.Events as List<PortfolioSite.Models.SocialEvent>;
    var skills = ViewBag.Skills as List<PortfolioSite.Models.Skill>;
}

<!-- NAV -->
<nav class="site-nav" id="siteNav">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            <span class="logo-initials">BSY</span>
        </a>
        <ul class="nav-links">
            <li><a href="#about" class="nav-link" data-tr="Hakkımda" data-en="About">About</a></li>
            <li><a href="#skills" class="nav-link" data-tr="Yetenekler" data-en="Skills">Skills</a></li>
            <li><a href="#projects" class="nav-link" data-tr="Projeler" data-en="Projects">Projects</a></li>
            <li><a href="#events" class="nav-link" data-tr="Aktiviteler" data-en="Events">Activity</a></li>
            <li><a href="#contact" class="nav-link" data-tr="İletişim" data-en="Contact">Contact</a></li>
        </ul>
        <button class="lang-toggle" id="langToggle" onclick="toggleLang()">
            <span class="lang-active">EN</span>
            <span class="lang-sep">/</span>
            <span class="lang-inactive">TR</span>
        </button>
        <button class="menu-toggle" id="menuToggle">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<!-- HERO -->
<section class="section-hero" id="hero">
    <div class="hero-bg">
        <div class="grid-overlay"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="noise"></div>
    </div>
    <div class="hero-content">
        <div class="hero-eyebrow reveal-up">
            <span class="eyebrow-line"></span>
            <span data-tr="3. Sınıf Yazılım Mühendisliği Öğrencisi" data-en="3rd Year Software Engineering Student">3rd Year Software Engineering Student</span>
        </div>
        <h1 class="hero-name reveal-up" style="animation-delay:0.1s">
            @(about?.FullNameEN ?? "Your Name")
        </h1>
        <p class="hero-tagline reveal-up" style="animation-delay:0.2s">
            <span data-tr="Kod yazmak bir sanattır." data-en="Writing code is an art.">Writing code is an art.</span>
            <span class="cursor-blink">_</span>
        </p>
        <div class="hero-cta reveal-up" style="animation-delay:0.3s">
            <a href="#projects" class="btn-primary" data-tr="Projeleri Gör" data-en="View Projects">View Projects</a>
            <a href="@(about?.GithubUrl ?? "#")" target="_blank" class="btn-ghost">GitHub ↗</a>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="scroll-line"></div>
        <span data-tr="Aşağı kaydır" data-en="Scroll">Scroll</span>
    </div>
</section>

<!-- ABOUT -->
<section class="section-about" id="about">
    <div class="section-container">
        <div class="section-label reveal-left">
            <span class="label-num">01</span>
            <span class="label-text" data-tr="Hakkımda" data-en="About Me">About Me</span>
        </div>
        <div class="about-grid">
            <div class="about-image-wrap reveal-left">
                @if (!string.IsNullOrEmpty(about?.ProfileImagePath))
                {
                    <img src="@about.ProfileImagePath" alt="Profile" class="about-img" />
                }
                else
                {
                    <div class="about-img-placeholder">
                        <svg viewBox="0 0 100 100" fill="none">
                            <circle cx="50" cy="35" r="22" stroke="#2563EB" stroke-width="2"/>
                            <path d="M10 90 Q10 65 50 65 Q90 65 90 90" stroke="#2563EB" stroke-width="2" fill="none"/>
                        </svg>
                    </div>
                }
                <div class="about-img-decoration"></div>
            </div>
            <div class="about-text reveal-right">
                <h2 class="section-heading" data-tr="@(about?.FullNameTR)" data-en="@(about?.FullNameEN)">@(about?.FullNameEN ?? "Buse Selin Yaman")</h2>
                <p class="about-bio" data-tr="@(about?.BiographyTR)" data-en="@(about?.BiographyEN)">@(about?.BiographyEN ?? "xXxXxXxXxXxXx ")</p>
                <div class="about-meta">
                    @if (!string.IsNullOrEmpty(about?.Location))
                    {
                        <div class="meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            <span>@about.Location</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(about?.Email))
                    {
                        <div class="meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <a href="mailto:@about.Email">@about.Email</a>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(about?.CvUrl))
                {
                    <a href="@about.CvUrl" class="btn-primary" data-tr="CV İndir" data-en="Download CV">Download CV</a>
                }
            </div>
        </div>
    </div>
</section>

<!-- SKILLS -->
<section class="section-skills" id="skills">
    <div class="section-container">
        <div class="section-label reveal-up">
            <span class="label-num">02</span>
            <span class="label-text" data-tr="Yetenekler" data-en="Skills">Skills</span>
        </div>
        <h2 class="section-heading reveal-up" data-tr="Yetenekler" data-en="Tech Stack">Tech Stack</h2>
        @{
            var skillGroups = skills?.GroupBy(s => s.Category).ToList();
        }
        @if (skillGroups != null)
        {
            <div class="skills-grid">
                @foreach (var group in skillGroups)
                {
                    <div class="skill-group reveal-up">
                        <h3 class="skill-category">@group.Key</h3>
                        <div class="skill-items">
                            @foreach (var skill in group)
                            {
                                <div class="skill-item">
                                    <div class="skill-header">
                                        <span class="skill-name">@skill.Name</span>
                                        <span class="skill-pct">@skill.Proficiency%</span>
                                    </div>
                                    <div class="skill-bar">
                                        <div class="skill-fill" style="--fill: @skill.Proficiency%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<!-- PROJECTS -->
<section class="section-projects" id="projects">
    <div class="section-container">
        <div class="section-label reveal-up">
            <span class="label-num">03</span>
            <span class="label-text" data-tr="Projeler" data-en="Projects">Projects</span>
        </div>
        <h2 class="section-heading reveal-up" data-tr="Projelerim" data-en="Projects">Projects</h2>
        <div class="projects-grid">
            @if (projects != null)
            {
                @foreach (var project in projects)
                {
                    var techList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(project.TechStack ?? "[]") ?? new();
                    <article class="project-card reveal-up">
                        <div class="project-img-wrap">
                            @if (!string.IsNullOrEmpty(project.ImagePath))
                            {
                                <img src="@project.ImagePath" alt="@project.TitleEN" class="project-img" />
                            }
                            else
                            {
                                <div class="project-img-placeholder">
                                    <svg viewBox="0 0 80 60" fill="none">
                                        <rect width="80" height="60" rx="4" fill="#0f172a"/>
                                        <rect x="8" y="8" width="64" height="10" rx="2" fill="#1e293b"/>
                                        <rect x="8" y="24" width="40" height="6" rx="2" fill="#1e293b"/>
                                        <rect x="8" y="36" width="55" height="6" rx="2" fill="#1e293b"/>
                                        <circle cx="66" cy="46" r="8" fill="#2563EB" opacity="0.3"/>
                                    </svg>
                                </div>
                            }
                            <div class="project-overlay">
                                <div class="overlay-links">
                                    @if (!string.IsNullOrEmpty(project.GithubUrl))
                                    {
                                        <a href="@project.GithubUrl" target="_blank" class="overlay-link">GitHub ↗</a>
                                    }
                                    @if (!string.IsNullOrEmpty(project.LiveUrl))
                                    {
                                        <a href="@project.LiveUrl" target="_blank" class="overlay-link" data-tr="Canlı ↗" data-en="Live ↗">Live ↗</a>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="project-body">
                            <h3 class="project-title" data-tr="@project.TitleTR" data-en="@project.TitleEN">@project.TitleEN</h3>
                            <p class="project-desc" data-tr="@project.DescriptionTR" data-en="@project.DescriptionEN">@project.DescriptionEN</p>
                            <div class="project-tech">
                                @foreach (var tech in techList)
                                {
                                    <span class="tech-tag">@tech</span>
                                }
                            </div>
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>

<!-- EVENTS -->
<section class="section-events" id="events">
    <div class="section-container">
        <div class="section-label reveal-up">
            <span class="label-num">04</span>
            <span class="label-text" data-tr="Aktiviteler" data-en="Social Events">Activities</span>
        </div>
        <h2 class="section-heading reveal-up" data-tr="Dahil Olduğum Topluluklar" data-en="Part of the Community">Part of the Community</h2>
        <div class="events-timeline">
            @if (events != null)
            {
                @foreach (var (ev, i) in events.Select((e, i) => (e, i)))
                {
                    <article class="event-card reveal-up @(i % 2 == 0 ? "event-left" : "event-right")">
                        <div class="event-connector">
                            <div class="connector-dot"></div>
                            <div class="connector-line"></div>
                        </div>
                        <div class="event-content">
                            @if (!string.IsNullOrEmpty(ev.ImagePath))
                            {
                                <div class="event-img-wrap">
                                    <img src="@ev.ImagePath" alt="@ev.TitleEN" class="event-img" />
                                </div>
                            }
                            <div class="event-meta">
                                <span class="event-type" data-tr="@ev.EventTypeTR" data-en="@ev.EventTypeEN">@ev.EventTypeEN</span>
                                <span class="event-date">@ev.EventDate.ToString("MMM yyyy")</span>
                            </div>
                            <h3 class="event-title" data-tr="@ev.TitleTR" data-en="@ev.TitleEN">@ev.TitleEN</h3>
                            <p class="event-desc" data-tr="@ev.DescriptionTR" data-en="@ev.DescriptionEN">@ev.DescriptionEN</p>
                            @if (!string.IsNullOrEmpty(ev.Location))
                            {
                                <span class="event-location">📍 @ev.Location</span>
                            }                     
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>

<!-- CONTACT -->
<section class="section-contact" id="contact">
    <div class="section-container">
        <div class="section-label reveal-up">
            <span class="label-num">05</span>
            <span class="label-text" data-tr="İletişim" data-en="Contact">Contact</span>
        </div>
        <div class="contact-content reveal-up">
            <h2 class="contact-heading" data-tr="Bana ulaşın." data-en="Let's build something together.">Contact Me.</h2>
            <p class="contact-sub" data-tr="Yeni fırsatlara, iş birliklerine ve projelere açığım." data-en="Open to new opportunities, collaborations, and projects.">Open to new opportunities, collaborations, and projects.</p>
            @if (!string.IsNullOrEmpty(about?.Email))
            {
                <a href="mailto:selinyaman3000@gmail.com" class="contact-email">@about.Email</a>
            }
            <div class="social-links">
                @if (!string.IsNullOrEmpty(about?.GithubUrl))
                {
                    <a href="@about.GithubUrl" target="_blank" class="social-link">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="22"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                    </a>
                }
                @if (!string.IsNullOrEmpty(about?.LinkedinUrl))
                {
                    <a href="@about.LinkedinUrl" target="_blank" class="social-link">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="22"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="site-footer">
    <div class="footer-inner">
        <span data-tr="Buse Selin Yaman" data-en="Buse Selin Yaman">Buse Selin Yaman</span>
        <span class="footer-heart">♥</span>  
    </div>
</footer>
