@model PortfolioSite.Models.Project
@{
    ViewData["Title"] = "Yeni Proje";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    bool isEdit = Model.Id > 0;
}

<div class="page-header">
    <div>
        <h1 class="page-title">@(isEdit ? "Proje Düzenle" : "Yeni Proje")</h1>
        <p class="page-subtitle">@(isEdit ? $"#{Model.Id}" : "Yeni proje ekle")</p>
    </div>
    <a href="/Admin/Projects" class="btn-cancel">← Geri</a>
</div>

<div class="form-card">
    <form method="post" action="@(isEdit ? $"/Admin/EditProject" : "/Admin/CreateProject")" enctype="multipart/form-data">
        @if (isEdit)
        {
            <input type="hidden" name="Id" value="@Model.Id" />
        }
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Başlık (Türkçe)</label>
                <input type="text" name="TitleTR" value="@Model.TitleTR" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label">Başlık (English)</label>
                <input type="text" name="TitleEN" value="@Model.TitleEN" class="form-input" required />
            </div>
            <div class="form-group full">
                <label class="form-label">Açıklama (Türkçe)</label>
                <textarea name="DescriptionTR" class="form-textarea">@Model.DescriptionTR</textarea>
            </div>
            <div class="form-group full">
                <label class="form-label">Description (English)</label>
                <textarea name="DescriptionEN" class="form-textarea">@Model.DescriptionEN</textarea>
            </div>
            <div class="form-group">
                <label class="form-label">GitHub URL</label>
                <input type="url" name="GithubUrl" value="@Model.GithubUrl" class="form-input" />
            </div>
            <div class="form-group">
                <label class="form-label">Canlı URL (opsiyonel)</label>
                <input type="url" name="LiveUrl" value="@Model.LiveUrl" class="form-input" />
            </div>
            <div class="form-group full">
                <label class="form-label">Tech Stack</label>
                <input type="text" name="techStackInput" value="@ViewBag.TechStackString" class="form-input"  />
                <span class="form-hint">Virgülle ayırın: C#, ASP.NET Core, PostgreSQL</span>
            </div>
            <div class="form-group">
                <label class="form-label">Sıra No</label>
                <input type="number" name="OrderIndex" value="@Model.OrderIndex" class="form-input" />
            </div>
            <div class="form-group">
                <label class="form-check">
                    <input type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") />
                    Öne Çıkan Proje
                </label>
            </div>
            <div class="form-group full">
                <label class="form-label">Proje Görseli</label>
                <input type="file" name="imageFile" class="form-input" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="image-preview" />
                }
                else
                {
                    <img src="" class="image-preview" style="display:none" />
                }
            </div>
        </div>
        <div class="form-actions" style="margin-top:24px">
            <button type="submit" class="btn-primary-admin">@(isEdit ? "Güncelle" : "Ekle")</button>
            <a href="/Admin/Projects" class="btn-cancel">İptal</a>
        </div>
    </form>
</div>
